{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openlimno.org/wedm/0.1/drifting_egg_params.schema.json",
  "title": "Drifting Egg Parameters",
  "description": "Parameters for 1D Lagrangian drifting-egg evaluation. SPEC v0.5 §3.1.3 + §4.2.6.",
  "type": "object",
  "required": [
    "species",
    "drift_distance_km_min",
    "drift_distance_km_max",
    "hatch_temp_days",
    "mortality_velocity_threshold_ms",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "species": { "type": "string", "pattern": "^[a-z_]+$" },
    "drift_distance_km_min": { "type": "number", "minimum": 0 },
    "drift_distance_km_max": { "type": "number", "minimum": 0 },
    "hatch_temp_days": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "number", "minimum": 0, "maximum": 50, "description": "Temp in degC" },
          { "type": "number", "minimum": 0, "description": "Days to hatch at that temp" }
        ],
        "items": false,
        "minItems": 2,
        "maxItems": 2
      },
      "description": "Piecewise (temp_C, hatch_days) curve"
    },
    "mortality_velocity_threshold_ms": {
      "type": "number",
      "minimum": 0,
      "description": "Velocity below which eggs settle and suffer mortality (m/s)"
    },
    "spawning_window": {
      "type": "object",
      "required": ["start_doy", "end_doy"],
      "properties": {
        "start_doy": { "type": "integer", "minimum": 1, "maximum": 366 },
        "end_doy": { "type": "integer", "minimum": 1, "maximum": 366 }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
