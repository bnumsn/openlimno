{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openlimno.org/wedm/0.1/species.schema.json",
  "title": "Species",
  "description": "Species master table entry. SPEC v0.5 §3.1.3.",
  "type": "object",
  "required": ["taxon_id", "scientific_name", "common_name_en"],
  "additionalProperties": false,
  "properties": {
    "taxon_id": {
      "type": "string",
      "pattern": "^[a-z_]+$",
      "description": "Stable internal identifier, e.g. oncorhynchus_mykiss"
    },
    "scientific_name": {
      "type": "string",
      "description": "Latin binomial, e.g. Oncorhynchus mykiss"
    },
    "common_name_en": { "type": "string" },
    "common_name_zh": { "type": "string" },
    "common_name_local": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2,3}(-[A-Z]{2})?$": { "type": "string" }
      },
      "description": "Locale-keyed common names, e.g. {\"fr\": \"truite arc-en-ciel\"}"
    },
    "iucn_status": {
      "type": "string",
      "enum": ["LC", "NT", "VU", "EN", "CR", "EW", "EX", "DD", "NE"]
    },
    "basin_distribution": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Basin codes where species is documented"
    },
    "migratory_type": {
      "type": "string",
      "enum": ["anadromous", "catadromous", "potamodromous", "amphidromous", "non_migratory"]
    },
    "drifting_egg": {
      "type": "boolean",
      "default": false,
      "description": "True for Asian carps, copper fish, etc.; triggers §4.2.6 evaluation availability"
    },
    "fishbase_id": { "type": "string" },
    "ncbi_taxon_id": { "type": "integer" },
    "notes": { "type": "string" }
  }
}
