{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openlimno.org/wedm/0.1/migration_corridor.schema.json",
  "title": "Migration Corridor",
  "description": "Migration corridor between life-stage habitat zones. SPEC v0.5 §3.1.3.",
  "type": "object",
  "required": ["species", "from_stage", "to_stage", "distance_km", "timing"],
  "additionalProperties": false,
  "properties": {
    "species": { "type": "string", "pattern": "^[a-z_]+$" },
    "from_stage": {
      "type": "string",
      "enum": ["egg", "larvae", "fry", "juvenile", "adult", "spawner", "spawning"]
    },
    "to_stage": {
      "type": "string",
      "enum": ["egg", "larvae", "fry", "juvenile", "adult", "spawner", "spawning"]
    },
    "distance_km": { "type": "number", "minimum": 0 },
    "timing": {
      "type": "object",
      "required": ["start_doy", "end_doy"],
      "properties": {
        "start_doy": { "type": "integer", "minimum": 1, "maximum": 366 },
        "end_doy": { "type": "integer", "minimum": 1, "maximum": 366 }
      }
    },
    "cue_variable": {
      "type": "string",
      "enum": ["temperature", "discharge", "photoperiod", "lunar", "olfactory", "combination"]
    },
    "cue_threshold_value": { "type": "number" },
    "cue_threshold_units": { "type": "string" },
    "barrier_geom_uri": {
      "type": "string",
      "format": "uri-reference",
      "description": "Optional GeoPackage / Shapefile URI of known barriers along corridor"
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
